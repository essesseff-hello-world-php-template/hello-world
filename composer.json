{
    "name": "hello-world/hello-world",
    "description": "Hello World PHP Slim application",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
